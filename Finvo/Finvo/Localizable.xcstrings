        }
      }
    },
    "Bu cüzdanı silmek istediğinize emin misiniz? Bu işlem geri alınamaz.": {
      "comment": "An alert message displayed when a user attempts to delete a wallet. It confirms the user's intention to delete the wallet and warns them that the action cannot be undone.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie diese Geldbörse löschen möchten? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete this wallet? This action cannot be undone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите удалить этот кошелёк? Это действие нельзя отменить."
          }
        }
      }
    },
