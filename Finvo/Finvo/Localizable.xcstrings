      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können keine Transaktionen hinzufügen, da Sie nur Betrachterrechte haben. Bitte fragen Sie den Eigentümer."
          }
        },
        "en" : {
