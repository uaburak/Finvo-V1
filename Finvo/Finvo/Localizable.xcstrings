    "Alt kategori ekleme, silme ve düzenleme işlemleri sadece Pro üyelerimiz içindir.": {
      "comment": "An alert message that appears when a user tries to add, delete, or edit a subcategory but is not a pro user.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Hinzufügen, Löschen und Bearbeiten von Unterkategorien ist nur für Pro-Mitglieder verfügbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adding, deleting, and editing subcategories is only available for Pro members."
