    "%@ hesabını silmek istediğinize emin misiniz? Bu işlem geri alınamaz.": {
      "comment": "An alert message displayed when the user attempts to delete a savings account. The message includes the name of the account and instructs the user to confirm the deletion.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie das Konto '%@' löschen möchten? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete the %@ account? This action cannot be undone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите удалить счёт '%@'? Это действие нельзя отменить."
          }
        }
      }
    },
