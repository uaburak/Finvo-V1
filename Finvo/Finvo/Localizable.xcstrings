            "value": "Um eine Unterkategorie hinzuzufügen, benötigen Sie 'Admin'- oder 'Gründer'-Berechtigungen in dieser Geldbörse."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To add a subcategory, you must have 'Admin' or 'Owner' permission in this wallet."
