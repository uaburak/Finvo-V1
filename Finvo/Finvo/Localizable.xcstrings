    "Bu cüzdandan ayrılmak istediğinize emin misiniz? Bir daha erişemeyeceksiniz.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie diese Geldbörse verlassen möchten? Sie haben keinen Zugriff mehr."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to leave this wallet? You will no longer have access."
