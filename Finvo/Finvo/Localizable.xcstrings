    "'%@' adında bir alt kategori bu grupta zaten mevcut.": {
      "comment": "An alert message that appears when trying to create an alt category with a name that is already taken within the same category group. The argument is the string “”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Unterkategorie namens '%@' existiert bereits in dieser Gruppe."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A subcategory named '%@' already exists in this group."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подкатегория с именем '%@' уже существует в этой группе."
          }
        }
      }
    },
    "'%@' adında bir kategori zaten mevcut. Lütfen farklı bir isim seçin.": {
      "comment": "An alert message that appears when trying to create a new category with a name that is already taken.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Kategorie namens '%@' existiert bereits. Bitte wählen Sie einen anderen Namen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A category named '%@' already exists. Please choose a different name."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Категория с именем '%@' уже существует. Пожалуйста, выберите другое имя."
          }
        }
      }
    },
    "'%@' kategorisini ve ona bağlı tüm verileri silmek istediğinizden emin misiniz?\n\n%@": {
      "comment": "An alert message that asks the user to confirm deleting a category and its associated data. The message includes the name of the category and a summary of the data that will be deleted.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie die Kategorie '%1$@' und alle zugehörigen Daten wirklich löschen?\n\n%2$@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete the '%1$@' category and all its associated data?\n\n%2$@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите удалить категорию '%1$@' и все связанные данные?\n\n%2$@"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "'%1$@' kategorisini ve ona bağlı tüm verileri silmek istediğinizden emin misiniz?\n\n%2$@"
          }
        }
      }
    },
